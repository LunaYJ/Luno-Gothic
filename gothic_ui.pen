                    "author": "Birmingham Museums Trust"
                  },
                  "width": "fill_container",
                  "height": 520,
                  "fill": {
                    "type": "image",
                    "enabled": true,
                    "url": "https://images.unsplash.com/photo-1695841396593-2a434e581bed?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzI3ODA2MTJ8&ixlib=rb-4.1.0&q=80&w=1080",
