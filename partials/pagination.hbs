<nav class="pagination" role="navigation">
  {{#if prev}}
    <a class="page-link page-link--prev" href="{{page_url prev}}">←</a>
  {{/if}}
  <span class="page-number">{{page}} / {{pages}}</span>
  {{#if next}}
    <a class="page-link page-link--next" href="{{page_url next}}">→</a>
  {{/if}}
</nav>
