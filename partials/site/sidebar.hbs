<aside class="profile-rail">
  <p class="profile-badge">{{@custom.profile_badge}}</p>
  <h1 class="profile-name"><a href="{{@site.url}}">{{@site.title}}</a></h1>
  <p class="profile-role">{{@custom.profile_role}}</p>

  {{#if @site.logo}}
    <img class="profile-avatar" src="{{@site.logo}}" alt="{{@site.title}}">
  {{else if @site.icon}}
    <img class="profile-avatar" src="{{@site.icon}}" alt="{{@site.title}}">
  {{else}}
    <div class="profile-avatar profile-avatar--placeholder"></div>
  {{/if}}

  <p class="profile-bio">{{@custom.profile_bio}}</p>

  <div class="profile-meta">
    <a href="{{@site.url}}/rss/" target="_blank" rel="noopener">RSS Feed</a>
    {{#if @site.facebook}}
      <a href="{{facebook_url}}" target="_blank" rel="noopener">Facebook</a>
    {{/if}}
    {{#if @site.twitter}}
      <a href="{{twitter_url}}" target="_blank" rel="noopener">X / Twitter</a>
    {{/if}}
  </div>
</aside>
