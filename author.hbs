{{!< default}}

{{#author}}
<section class="archive-hero">
  <p class="section-kicker">AUTHOR</p>
  <h1 class="archive-title">{{name}}</h1>
  {{#if bio}}<p class="archive-desc">{{bio}}</p>{{/if}}
</section>
{{/author}}

<section class="archive-body">
  <div class="archive-list">
    {{#foreach posts}}
      {{> "site/post-card"}}
    {{/foreach}}
  </div>
  {{pagination}}
</section>
