{{!< default}}

{{#tag}}
<section class="archive-hero">
  <p class="section-kicker">ARCHIVE</p>
  <h1 class="archive-title">{{name}}</h1>
  {{#if description}}<p class="archive-desc">{{description}}</p>{{/if}}
  <div class="tag-filter">
    {{#get "tags" limit="10"}}
      {{#foreach tags}}
        <a href="{{url}}">{{name}}</a>
      {{/foreach}}
    {{/get}}
  </div>
</section>
{{/tag}}

<section class="archive-body">
  <div class="archive-list">
    {{#foreach posts}}
      {{> "site/post-card"}}
    {{/foreach}}
  </div>
  {{pagination}}
</section>
