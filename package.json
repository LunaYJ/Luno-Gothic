{
  "name": "luno-gothic",
  "description": "a Ghost theme",
  "version": "1.3.1",
  "keywords": [
    "ghost-theme",
    "luno",
    "gothic",
    "dark",
    "blog"
  ],
  "author": {
    "name": "Luna YJ",
    "email": "luna_yj@hotmail.com"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "ghost": ">=5.0.0",
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "license": "MIT",
  "scripts": {
    "dev": "run-p dev:build dev:serve",
    "dev:build": "vite build --watch --mode development",
    "dev:serve": "browser-sync start --config bs-config.js",
    "build": "vite build --mode production",
    "zip": "pnpm run build && bestzip luno-gothic.zip assets/ partials/ *.hbs package.json",
    "clean": "rm -rf assets/built"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "bestzip": "^2.2.1",
    "browser-sync": "^3.0.2",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.77.8",
    "semantic-release": "^24.2.3",
    "vite": "^5.4.11"
  },
  "config": {
    "posts_per_page": 10,
    "image_sizes": {
      "s": {
        "width": 400
      },
      "m": {
        "width": 750
      },
      "l": {
        "width": 1200
      },
      "xl": {
        "width": 2000
      }
    },
    "card_assets": true,
    "custom": {
      "profile_description": {
        "type": "text",
        "default": ""
      },
      "show_hero": {
        "type": "boolean",
        "default": false,
        "description": "是否显示主屏"
      },
      "hero_title": {
        "type": "text",
        "default": "",
        "description": "主屏标题"
      },
      "hero_desc": {
        "type": "text",
        "default": "",
        "description": "主屏描述"
      },
      "hero_poster": {
        "type": "image",
        "description": "主屏图片"
      },
      "profile_social_email": {
        "type": "text",
        "default": "",
        "description": "邮箱链接"
      },
      "profile_social_github": {
        "type": "text",
        "default": "",
        "description": "Github 链接"
      },
      "comments_system": {
        "description": "选择评论系统 - off: 关闭, built-in: 内置, disqus: Disqus",
        "type": "select",
        "options": [
          "off",
          "built-in",
          "disqus"
        ],
        "default": "built-in"
      },
      "shortname_by_disqus": {
        "type": "text",
        "description": "Disqus 的 shortname，如：https://<shortname>.disqus.com/",
        "default": ""
      },
      "mask_light_type": {
        "type": "select",
        "options": [
          "line",
          "conic"
        ],
        "default": "line",
        "description": "选择光照样式"
      },
      "mask_light_color": {
        "type": "color",
        "default": "#ff1744",
        "description": "选择光照颜色"
      },
      "mask_light_animation": {
        "type": "boolean",
        "default": false,
        "description": "是否开启光照动画"
      },
      "footer_position": {
        "type": "select",
        "options": [
          "default",
          "sticky"
        ],
        "default": "default",
        "description": "选择页脚位置 - default: 默认, sticky: 固定"
      },
      "footer_icp": {
        "type": "text",
        "default": "",
        "description": "ICP 备案号"
      },
      "donate_on": {
        "type": "boolean",
        "description": "是否开启打赏功能",
        "default": false
      },
      "donate_text_1": {
        "type": "text",
        "default": "支付宝打赏",
        "description": "打赏栏一的文本描述"
      },
      "donate_img_1": {
        "type": "image"
      },
      "donate_text_2": {
        "type": "text",
        "default": "微信打赏",
        "description": "打赏栏二的文本描述"
      },
      "donate_img_2": {
        "type": "image"
      }
    }
  }
}
