{{#get "posts" filter="featured:true" limit="3" include="authors,tags" as |featured|}}
  {{#if featured}}
    <section class="section-block">
      <p class="section-kicker">FEATURED</p>
      <div class="section-rule"></div>
      <h2 class="section-title">Selected Writings</h2>
      <div class="featured-grid">
        {{#foreach featured}}
          {{> "site/post-card"}}
        {{/foreach}}
      </div>
    </section>
  {{/if}}
{{/get}}

<section id="latest" class="section-block latest-section">
  <p class="section-kicker">LATEST POSTS</p>
  <div class="section-rule"></div>
  <div class="latest-list">
    {{#foreach posts}}
      <article class="">
        <a class="latest-row" href="{{url}}">
          <h3>{{title}}</h3>
          <p class="artical-info">{{date published_at format="YYYY/MM/DD"}} · {{reading_time}}</p>
        </a>
      </article>
    {{/foreach}}
  </div>
  {{pagination}}
</section>

